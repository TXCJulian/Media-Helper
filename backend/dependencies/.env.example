# Media Renamer - Environment Variables

# === Path Configuration ===
# Base path for all media (in container)
BASE_PATH=/media

# Subfolder for TV Shows
TVSHOW_FOLDER_NAME=TV Shows

# Subfolder for Music
MUSIC_FOLDER_NAME=Music

# === API-Keys ===
# TMDB API Key for Episode Renamer (required)
# Get yours at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# === File Extensions (comma-separated) ===
# Valid video file formats
VALID_VIDEO_EXT=.mp4,.mkv,.mov,.avi

# Valid music file formats
VALID_MUSIC_EXT=.flac,.wav,.mp3

# === CORS ===
# Comma-separated list of allowed origins (default: http://localhost:3333)
#ALLOWED_ORIGINS=http://localhost:3333

# === Lyric Transcriber ===
# URL of the lyric-transcriber service (runs on a separate machine with GPU)
# Example: http://192.168.1.100:3334
# When using --profile gpu, defaults to http://lyric-transcriber:3334
TRANSCRIBER_URL=

# Genius API token for lyrics correction (only needed with --profile gpu)
# Get yours at: https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# === Feature Toggles ===
# Comma-separated list of enabled features: episodes, music, lyrics
# Default: episodes,music (lyrics requires TRANSCRIBER_URL)
ENABLED_FEATURES=episodes,music
